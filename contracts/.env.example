# Nexus Testnet RPC (chain 3945)
NEXUS_TESTNET_RPC_URL=https://testnet.rpc.nexus.xyz

# Nexus Mainnet RPC (chain 3946)
NEXUS_RPC_URL=https://mainnet.rpc.nexus.xyz

# Deployer private key (fresh, dedicated key — never a high-value wallet)
PRIVATE_KEY=0x...

# Optional: Nexus Explorer API key for contract verification
EXPLORER_API_KEY=

# Optional: Nexus WSS API key for live websocket updates
NEXUS_WS_API_KEY=
